<?xml version="1.0" encoding="UTF-8" ?>
<interface>
    <template class="PIWindowController" parent="GtkApplicationWindow">
        <child>
            <object class="GtkBox" id="contents">
                <property name="hexpand">true</property>
                <property name="vexpand">true</property>
                <child>
                    <object class="GtkFrame">
                        <property name="hexpand">true</property>
                        <property name="halign">center</property>
                        <property name="valign">center</property>
                        <property name="css-classes">Window-empty</property>
                        <child>
                            <object class="GtkBox">
                                <property name="orientation">vertical</property>
                                <child>
                                    <object class="GtkLabel">
                                        <property name="label">No puppet document is open.</property>
                                    </object>
                                </child>
                                <child>
                                    <object class="GtkButton">
                                        <property name="action-name">win.open</property>
                                        <child>
                                            <object class="GtkLabel">
                                                <property name="label">Open...</property>
                                            </object>
                                        </child>
                                    </object>
                                </child>
                            </object>
                        </child>
                    </object>
                </child>
            </object>
        </child>
        <property name="title">Puppet Inspector</property>
        <property name="default-width">640</property>
        <property name="default-height">480</property>
        <property name="titlebar">
            <object class="GtkHeaderBar">
                <child type="start">
                    <object class="GtkButton" id="back_button">
                        <property name="icon-name">go-previous</property>
                        <property name="action-name">doc.back</property>
                    </object>
                </child>
                <child type="start">
                    <object class="GtkButton" id="fwd_button">
                        <property name="icon-name">go-next</property>
                        <property name="action-name">doc.fwd</property>
                    </object>
                </child>
                <child type="end">
                    <object class="GtkMenuButton" id="main_menu_button">
                        <property name="icon-name">open-menu-symbolic</property>
                    </object>
                </child>
                <child type="end">
                    <object class="GtkButton" id="preview_button">
                        <property name="icon-name">open-menu-symbolic</property>
                        <property name="label">Preview</property>
                        <property name="action-name">doc.preview</property>
                    </object>
                </child>
            </object>
        </property>
        <object class="GtkFileDialog" id="filepicker">
            <property name="title" translatable="yes">Select puppet...</property>
            <property name="filters">
                <object class="GListStore">
                    <child>
                        <object class="GtkFileFilter">
                            <property name="name" translatable="yes">Inochi2D Puppet (*.inp)</property>
                            <!-- TODO: Does Inochi have a mimetype? -->
                            <patterns>
                                <pattern>*.inp</pattern>
                            </patterns>
                        </object>
                    </child>
                </object>
            </property>
        </object>
    </template>
    <menu id="main_menu">
        <section>
            <item>
                <attribute name="label" translatable="yes">Open...</attribute>
                <attribute name="action">win.open</attribute>
            </item>
        </section>
        <section>
            <item>
                <attribute name="label" translatable="yes">Exit</attribute>
                <attribute name="action">window.close</attribute>
            </item>
        </section>
    </menu>
</interface>